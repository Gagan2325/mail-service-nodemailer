# Server Configuration
PORT=3000
NODE_ENV=development

# SMTP Configuration (Optional - can be provided in request)
# These are defaults, but each request can override them
DEFAULT_SMTP_HOST=smtp.gmail.com
DEFAULT_SMTP_PORT=587
DEFAULT_SMTP_USER=your-email@gmail.com
DEFAULT_SMTP_PASSWORD=your-app-password

# Email Configuration
DEFAULT_FROM_EMAIL=noreply@yourcompany.com
DEFAULT_FROM_NAME=Your Company Name

# Rate Limiting
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Security
ENABLE_CORS=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Nodemailer TLS Rejection
REJECT_UNAUTHORIZED=false
