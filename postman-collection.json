    {
      "name": "Send Email - Invalid Request",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is failure', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql(false);",
              "});",
              "",
              "pm.test('Response has errors', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.errors).to.exist;",
              "});"
            ],
