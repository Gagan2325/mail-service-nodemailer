    {
      "name": "Send Email - Gmail",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is success', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql(true);",
              "});",
              "",
              "pm.test('Response has messageId', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.messageId).to.exist;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"smtp_host\": \"smtp.gmail.com\",\n  \"smtp_port\": 587,\n  \"smtp_user\": \"your-email@gmail.com\",\n  \"smtp_pass\": \"your-app-password\",\n  \"from_email\": \"your-email@gmail.com\",\n  \"from_name\": \"My Company\",\n  \"to_email\": \"recipient@example.com\",\n  \"subject\": \"Welcome to Email Service\",\n  \"body\": \"<h1>Welcome!</h1><p>This is a test email from the Email Sending Service.</p>\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/send-email",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "send-email"
          ]
        },
        "description": "Send an email using Gmail SMTP"
      },
      "response": []
    },
